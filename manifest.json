{
  "manifest_version": 3,
  "name": "SmartClip",
  "version": "1.0.0",
  "description": "SmartClip Chrome extension",
  "permissions": ["activeTab", "storage", "tabs"],

  "icons": {
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartClip",
    "default_icon": "icon.png"
  }
}